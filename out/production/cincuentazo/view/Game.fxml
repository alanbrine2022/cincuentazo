<BorderPane maxHeight="600" maxWidth="900" minHeight="400" minWidth="700" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #0C5927;" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.GameController">
